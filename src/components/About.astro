---
import { Image } from 'astro:assets';
import SectionHeading from '@/components/SectionHeading.astro';
import photo from '@/assets/photo.png';

const stats = [
  { value: '15+', label: 'Years in Development' },
  { value: '45+', label: 'Projects Delivered' },
  { value: '25+', label: 'Happy Clients' },
];
---

<section class="about section" id="about">
  <div class="about__inner container">
    <div class="about__content">
      <SectionHeading label="About" title="A bit about me" />

      <div class="about__text" data-animate data-delay="1">
        <p>
          I'm Roman, a UI/UX Lead Developer based in Odesa, Ukraine, with over
          15 years of experience designing and delivering high-quality digital
          products. My work spans the full product lifecycle — from concept and
          strategy to implementation and continuous improvement.
        </p>
        <p>
          Throughout my career, I've contributed to a wide range of projects,
          from bespoke digital experiences to complex, large-scale platforms.
          I've collaborated with clients across the U.S., Norway, Germany, and
          Austria, delivering tailored solutions in industries including
          healthcare, fintech, entertainment, gaming, telecommunications, and
          artificial intelligence.
        </p>
        <p>
          I approach each project with a strong focus on user experience,
          product thinking, and execution quality. By aligning user needs with
          business goals, I help create intuitive, scalable solutions that
          deliver real impact. Whether leading a team or driving initiatives
          independently, I consistently deliver results — even under demanding
          timelines.
        </p>
      </div>
    </div>

    <aside class="about__sidebar">
      <div class="about__portrait" data-animate>
        <Image
          src={photo}
          alt="Roman Razumieienko"
          width={400}
          height={400}
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="about__stats" aria-label="Key statistics">
        {stats.map((stat, i) => (
          <div class="about__stat" data-animate data-delay={String(i + 1)}>
            <span class="about__stat-value">{stat.value}</span>
            <span class="about__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>

<style>
  .about__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__text p {
    color: var(--color-text-secondary);
    font-weight: 300;
    line-height: 1.8;
  }

  /* --- Sidebar (portrait + stats) --- */

  .about__sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  /* --- Portrait --- */

  .about__portrait {
    width: 12.5rem;
    aspect-ratio: 1;
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 45%, black 25%, transparent 72%);
    mask-image: radial-gradient(ellipse 80% 80% at 50% 45%, black 25%, transparent 72%);
  }

  .about__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(20%) contrast(1.05);
    transition: filter var(--duration-slow) var(--ease-smooth);
  }

  .about__portrait:hover img {
    filter: grayscale(0%) contrast(1);
  }

  /* --- Stats --- */

  .about__stats {
    display: flex;
    flex-direction: row;
    gap: var(--space-lg);
    justify-content: flex-start;
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .about__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
  }

  .about__stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  @media (min-width: 1024px) {
    .about__inner {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }

    .about__sidebar {
      border-left: 1px solid var(--color-border);
      padding-left: var(--space-xl);
      gap: var(--space-xl);
    }

    .about__portrait {
      width: 17.5rem;
      aspect-ratio: 3 / 4;
    }

    .about__stats {
      flex-direction: row;
      gap: var(--space-lg);
    }
  }
</style>
