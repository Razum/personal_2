---
import SectionHeading from './SectionHeading.astro';

const stats = [
  { value: '15+', label: 'Years in Development' },
  { value: '45+', label: 'Projects Delivered' },
  { value: '25+', label: 'Happy Clients' },
];
---

<section class="about section" id="about">
  <div class="about__inner container">
    <div class="about__content">
      <SectionHeading label="About" title="A bit about me" />

      <div class="about__text" data-animate data-delay="1">
        <p>
          I'm Roman, a seasoned Front-End Developer based in Odesa, Ukraine,
          with over 14 years of experience in planning, coding, testing, and
          maintaining both websites and applications. My career has been defined
          by a continuous pursuit of excellence and innovation.
        </p>
        <p>
          Throughout my professional journey, I have contributed to a diverse
          range of projects — from small, bespoke websites to expansive, complex
          web applications. I have collaborated with clients across the U.S.,
          Norway, Germany, and Austria, delivering tailored solutions in
          industries such as healthcare, fintech, entertainment, gaming,
          telecommunications, and artificial intelligence.
        </p>
        <p>
          I approach each project with a commitment to thorough analysis,
          ensuring that the best strategies and most appropriate toolsets are
          selected. Whether working as part of a dynamic team or independently as
          a lead developer, I pride myself on delivering high-quality results
          even under the most challenging deadlines.
        </p>
      </div>
    </div>

    <aside class="about__sidebar">
      <div class="about__portrait" data-animate>
        <img
          src="/photo.png"
          alt="Roman Razumieienko"
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="about__stats" aria-label="Key statistics">
        {stats.map((stat, i) => (
          <div class="about__stat" data-animate data-delay={String(i + 1)}>
            <span class="about__stat-value">{stat.value}</span>
            <span class="about__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>

<style>
  .about__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__text p {
    color: var(--color-text-secondary);
    font-weight: 300;
    line-height: 1.8;
  }

  /* --- Sidebar (portrait + stats) --- */

  .about__sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  /* --- Portrait --- */

  .about__portrait {
    width: 200px;
    aspect-ratio: 1;
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 45%, black 25%, transparent 72%);
    mask-image: radial-gradient(ellipse 80% 80% at 50% 45%, black 25%, transparent 72%);
  }

  .about__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(20%) contrast(1.05);
    transition: filter var(--duration-slow) var(--ease-smooth);
  }

  .about__portrait:hover img {
    filter: grayscale(0%) contrast(1);
  }

  /* --- Stats --- */

  .about__stats {
    display: flex;
    flex-direction: row;
    gap: var(--space-lg);
    justify-content: flex-start;
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .about__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
  }

  .about__stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  @media (min-width: 1024px) {
    .about__inner {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }

    .about__sidebar {
      border-left: 1px solid var(--color-border);
      padding-left: var(--space-xl);
      padding-top: calc(var(--space-xl) + var(--space-lg));
      gap: var(--space-xl);
    }

    .about__portrait {
      width: 280px;
      aspect-ratio: 3 / 4;
    }

    .about__stats {
      flex-direction: row;
      gap: var(--space-lg);
    }
  }
</style>
