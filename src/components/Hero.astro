<section class="hero">
  <canvas class="hero__canvas" aria-hidden="true"></canvas>

  <div class="hero__content container">
    <p class="hero__greeting" data-animate>UI/UX Lead Developer</p>
    <h1 class="hero__name" data-animate data-delay="1">
      <span class="hero__name-line">Roman</span>
      <span class="hero__name-line">Razumieienko</span>
    </h1>
    <p class="hero__tagline" data-animate data-delay="2">
      Crafting polished digital experiences with<br class="hero__br" />
      <span class="hero__accent">15+ years</span> of precision & care
    </p>
  </div>

  <div class="hero__scroll" data-animate data-delay="4" aria-hidden="true">
    <span class="hero__scroll-text">Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    min-height: 100dvh;
    padding-top: var(--header-height);
    text-align: center;
    overflow: hidden;
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .hero__greeting {
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero__name-line {
    display: block;
  }

  .hero__tagline {
    max-width: 520px;
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .hero__br {
    display: none;
  }

  .hero__accent {
    color: var(--color-accent);
    font-weight: 400;
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .hero__scroll-text {
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.4; transform: scaleY(0.6); }
  }

  @media (min-width: 768px) {
    .hero__br {
      display: inline;
    }
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('.hero__canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const WIRE_COUNT = 12;
    const SEGMENTS = 80;

    const wires = Array.from({ length: WIRE_COUNT }, (_, i) => {
      const t = i / (WIRE_COUNT - 1);
      return {
        baseY: 0.12 + t * 0.76,
        amplitude: 18 + Math.random() * 35,
        frequency: 1.2 + Math.random() * 1.5,
        speed: 0.0003 + Math.random() * 0.0004,
        phase: Math.random() * Math.PI * 2,
        opacity: 0.06 + Math.random() * 0.12,
        width: 0.5 + Math.random() * 1,
      };
    });

    let w = 0;
    let h = 0;
    let dpr = 1;

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw(t: number) {
      ctx.clearRect(0, 0, w, h);
      ctx.lineCap = 'round';

      for (const wire of wires) {
        const time = prefersReduced ? 0 : t * wire.speed;
        ctx.beginPath();

        for (let i = 0; i <= SEGMENTS; i++) {
          const pct = i / SEGMENTS;
          const x = pct * w;
          const wave1 = Math.sin(pct * Math.PI * wire.frequency + time + wire.phase) * wire.amplitude;
          const wave2 = Math.sin(pct * Math.PI * wire.frequency * 0.5 + time * 0.7 + wire.phase + 1.3) * wire.amplitude * 0.4;
          const y = wire.baseY * h + wave1 + wave2;

          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }

        const fade = ctx.createLinearGradient(0, 0, w, 0);
        fade.addColorStop(0, 'rgba(201, 169, 110, 0)');
        fade.addColorStop(0.1, `rgba(201, 169, 110, ${wire.opacity})`);
        fade.addColorStop(0.5, `rgba(201, 169, 110, ${wire.opacity * 1.2})`);
        fade.addColorStop(0.9, `rgba(201, 169, 110, ${wire.opacity})`);
        fade.addColorStop(1, 'rgba(201, 169, 110, 0)');

        ctx.strokeStyle = fade;
        ctx.lineWidth = wire.width;
        ctx.stroke();
      }

      requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize);

    if (prefersReduced) {
      draw(0);
    } else {
      requestAnimationFrame(draw);
    }
  }
</script>
