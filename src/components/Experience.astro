---
import SectionHeading from '@/components/SectionHeading.astro';
import { experience } from '@/data/experience';
---

<section class="experience section" id="experience">
  <div class="container">
    <SectionHeading label="Experience" title="Where I've been" />

    <div class="timeline">
      {experience.map((entry, i) => (
        <article
          class="timeline__entry"
          data-animate
          data-delay={String(Math.min(i + 1, 3))}
        >
          <div class="timeline__period">
            <time>{entry.period}</time>
          </div>
          <div class="timeline__marker" aria-hidden="true">
            <span class="timeline__dot"></span>
          </div>
          <div class="timeline__body">
            <h3 class="timeline__title">{entry.title}</h3>
            <p class="timeline__company">{entry.company}</p>
            {entry.description && (
              <p class="timeline__desc">{entry.description}</p>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: linear-gradient(
      to bottom,
      var(--color-accent),
      var(--color-border) 30%,
      var(--color-border) 70%,
      transparent
    );
  }

  .timeline__entry {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 var(--space-md);
    padding-bottom: var(--space-xl);
    position: relative;
  }

  .timeline__entry:last-child {
    padding-bottom: 0;
  }

  .timeline__period {
    grid-column: 2;
    grid-row: 1;
  }

  .timeline__period time {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 400;
  }

  .timeline__marker {
    grid-column: 1;
    grid-row: 1 / -1;
    display: flex;
    justify-content: center;
    padding-top: 6px;
    width: 15px;
  }

  .timeline__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  .timeline__body {
    grid-column: 2;
    grid-row: 2;
    padding-top: var(--space-xs);
  }

  .timeline__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.3;
  }

  .timeline__company {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .timeline__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-top: var(--space-xs);
    max-width: 540px;
  }

  @media (min-width: 1024px) {
    .timeline::before {
      left: 200px;
    }

    .timeline__entry {
      grid-template-columns: 185px auto 1fr;
      grid-template-rows: auto;
    }

    .timeline__period {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
      padding-top: 2px;
    }

    .timeline__marker {
      grid-column: 2;
      grid-row: 1;
    }

    .timeline__body {
      grid-column: 3;
      grid-row: 1;
      padding-top: 0;
    }
  }
</style>
